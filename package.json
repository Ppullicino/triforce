{
  "name": "triforce",
  "version": "0.1.0",
  "description": "Multi-agent development orchestrator",
  "main": "orchestrator.js",
  "type": "module",
  "workspaces": [
    "clients/shared",
    "packages/*"
  ],
  "bin": {
    "triforce": "./cli.js"
  },
  "files": [
    "agent.js",
    "cli.js",
    "cli-input.js",
    "models.config.json",
    "orchestrator.js",
    "public/",
    "sandbox.js",
    "server.js",
    "usage.js",
    "workspace.js",
    "RUNNING.md",
    "install-service.sh",
    "triforce.service"
  ],
  "scripts": {
    "start": "node server.js",
    "cli": "node cli.js",
    "test": "npm run test:server && npm run test --workspaces --if-present",
    "test:server": "node --test test/*.test.js",
    "build": "npm run build --workspace @triforce/protocol && npm run build --workspace @triforce/client",
    "typecheck": "npm run typecheck --workspace @triforce/protocol && npm run typecheck --workspace @triforce/client",
    "lint": "npm run lint --workspace @triforce/protocol && npm run lint --workspace @triforce/client",
    "dev:client": "npm run dev --workspace @triforce/client"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/genai": "^2.6.0",
    "dotenv": "^16.0.0",
    "express": "^5.2.1",
    "openai": "^6.39.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "pngjs": "^7.0.0"
  }
}
